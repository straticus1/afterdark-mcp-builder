# MCP Server Environment Configuration
# Generated by Ansible

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# API Authentication
API_KEY={{ api_key }}

# Enabled Modules
MODULES=filesystem,memory,terminal

# Filesystem Configuration
ALLOWED_PATHS={{ app_dir }}/workspace,/tmp

# Logging
DEBUG=0

# Docker Volumes
WORKSPACE_PATH={{ app_dir }}/workspace
