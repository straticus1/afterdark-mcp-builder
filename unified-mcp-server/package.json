{
  "name": "@unified/mcp-server-everything",
  "version": "1.0.0",
  "description": "Unified MCP server combining filesystem, memory, terminal, browser, and documentation features",
  "license": "MIT",
  "author": "Unified MCP Team",
  "type": "module",
  "bin": {
    "unified-mcp-server": "dist/index.js",
    "unified-mcp-http": "dist/http-server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "start:dev": "tsc && node dist/http-server.js",
    "dev": "tsc --watch & node --watch dist/http-server.js",
    "docker:build": "docker build -t unified-mcp-server .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "@vscode/ripgrep": "^1.15.9",
    "cors": "^2.8.5",
    "cross-fetch": "^4.1.0",
    "diff": "^5.1.0",
    "express": "^4.21.1",
    "fastest-levenshtein": "^1.0.16",
    "glob": "^10.3.10",
    "isbinaryfile": "^5.0.4",
    "minimatch": "^10.0.1",
    "puppeteer-core": "^24.23.0",
    "undici": "^6.6.3",
    "yargs": "^18.0.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/diff": "^5.0.9",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "shx": "^0.3.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "filesystem",
    "memory",
    "terminal",
    "browser",
    "chrome",
    "documentation",
    "unified",
    "claude",
    "ai"
  ]
}