# ========================================
# After Dark Systems Unified MCP Server
# Environment Configuration
# ========================================

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# API Authentication (recommended for production)
API_KEY=your-secret-api-key-here

# Enabled Modules (comma-separated)
# Available: filesystem,memory,terminal,oci,cloudflare,neon,github,docker,twilio
MODULES=filesystem,memory,terminal,oci,cloudflare,neon,github,docker,twilio

# HTTPS Configuration (optional)
ENABLE_HTTPS=false
CERT_PATH=/path/to/cert.pem
KEY_PATH=/path/to/key.pem

# Filesystem Module Configuration
ALLOWED_PATHS=/workspace,/app/data

# Terminal Module Configuration
MAX_TIMEOUT=30000

# Memory Module Configuration
MEMORY_PERSIST_PATH=/app/data/memory

# ========================================
# Cloud Provider Credentials
# ========================================

# Oracle Cloud Infrastructure (OCI)
OCI_TENANCY_ID=ocid1.tenancy.oc1..xxxx
OCI_REGION=us-ashburn-1

# Cloudflare
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Neon (Serverless PostgreSQL)
NEON_API_KEY=your-neon-api-key

# GitHub
GITHUB_TOKEN=your-github-personal-access-token

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ========================================
# Docker Configuration
# ========================================
DOCKER_SOCKET=/var/run/docker.sock
WORKSPACE_PATH=./workspace

# Logging
DEBUG=0
